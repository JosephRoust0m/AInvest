{
  "name": "chatbot-api",
  "version": "1.0.0",
  "description": "A TypeScript-based ChatBot API with OpenAI integration",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "ts-node src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:docker": "docker build -f Dockerfile.test -t chatbot-test . && docker run --rm chatbot-test"
  },
  "keywords": ["chatbot", "openai", "typescript", "express"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "body-parser": "^1.20.2",
    "bcrypt": "^5.1.1",
    "axios": "^1.6.2",
    "@googlemaps/google-maps-services-js": "^3.3.42",
    "fs-extra": "^11.1.1",
    "node-cron": "^3.0.3",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.8",
    "@types/supertest": "^2.0.16",
    "@types/fs-extra": "^11.0.4",
    "@types/node-cron": "^3.0.11",
    "@types/lodash": "^4.14.202",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3"
  }
}